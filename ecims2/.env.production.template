# Required production overrides
ECIMS_ENVIRONMENT=prod
ECIMS_JWT_SECRET=replace-with-strong-random-value
ECIMS_BOOTSTRAP_ADMIN_TOKEN=replace-with-bootstrap-token
ECIMS_BOOTSTRAP_ADMIN_USERNAME=ecims-admin
ECIMS_BOOTSTRAP_ADMIN_PASSWORD=replace-with-strong-password

ECIMS_LICENSE_PATH=/opt/ecims/configs/license.ecims
ECIMS_LICENSE_PUBLIC_KEY_PATH=/opt/ecims/server/app/license/public_key.pem

ECIMS_SECURITY_POLICY_PATH=/opt/ecims/configs/security.policy.json
ECIMS_SECURITY_POLICY_SIG_PATH=/opt/ecims/configs/security.policy.sig
ECIMS_SECURITY_POLICY_PUBLIC_KEY_PATH=/opt/ecims/configs/security.policy.public.pem

ECIMS_DEVICE_ALLOW_TOKEN_PUBLIC_KEY_PATH=/opt/ecims/configs/device_allow_token_public.pem
ECIMS_DEVICE_ALLOW_TOKEN_PRIVATE_KEY_PATH=/etc/ecims/keys/device_allow_token_private.pem

# Enable at-rest encryption with one of the following:
ECIMS_DATA_ENCRYPTION_ENABLED=true
# ECIMS_DATA_KEY_PATH=/etc/ecims/keys/data_keys.json
# or
# ECIMS_DATA_KEY_B64=<base64-encoded-32-byte-key>

# Optional agent LAN auto-discovery
# ECIMS_DISCOVERY_ENABLED=true
# ECIMS_DISCOVERY_UDP_PORT=40110
# ECIMS_DISCOVERY_SERVER_URL=https://ecims.example.local:8010
# ECIMS_DISCOVERY_HTTP_PORT=8010
# ECIMS_DISCOVERY_MDNS_ENABLED=false
# ECIMS_DISCOVERY_MDNS_SERVICE_NAME=ecims-server
# ECIMS_DISCOVERY_MDNS_SERVICE_TYPE=_ecims._tcp.local.
